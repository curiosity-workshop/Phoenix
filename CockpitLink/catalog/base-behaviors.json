    {
      "id": "lights.beacon",
      "label": "Beacon lights",
      "kind": "toggle",
      "valueType": "bool",
      "desiredCapability": {
        "read": true,
        "write": true,
        "command": true
      },
      "defaultUpdate": {
        "rateMs": 100,
        "bucket": 1
      },
      "bindings": {
        "xplane": {
          "default": {
            "capability": {
              "read": "native",
              "write": "emulatedByCommand",
              "command": "native"
            },
            "read": {
              "dataref": "sim/cockpit/electrical/beacon_lights_on",
              "type": "int"
            },
            "write": {
              "strategy": "setViaToggleWhenKnown",
              "requiresRead": true,
              "toggleCommand": "sim/lights/beacon_lights_toggle",
              "trueValue": 1,
              "falseValue": 0
            }
          }
        },
        "msfs": {
          "default": {
            "capability": {
              "read": "native",
              "write": "unsupported",
              "command": "native"
            },
            "notes": "Illustrative placeholder showing that simulator capabilities can differ."
          }
        }
      }
    },
